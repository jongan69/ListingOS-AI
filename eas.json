{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0",
        "LISTINGOS_APS_ENVIRONMENT": "development",
        "EXPO_PUBLIC_REVENUECAT_MODE": "test",
        "EXPO_PUBLIC_REVENUECAT_TEST_API_KEY": "REVENUECAT_TEST_PUBLIC_API_KEY"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0",
        "LISTINGOS_APS_ENVIRONMENT": "development",
        "EXPO_PUBLIC_REVENUECAT_MODE": "test",
        "EXPO_PUBLIC_REVENUECAT_TEST_API_KEY": "REVENUECAT_TEST_PUBLIC_API_KEY"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "EXPO_USE_PRECOMPILED_MODULES": "0",
        "LISTINGOS_APS_ENVIRONMENT": "production",
        "EXPO_PUBLIC_REVENUECAT_PROD_API_KEY": "REVENUECAT_PROD_PUBLIC_API_KEY",
        "EXPO_PUBLIC_REVENUECAT_MODE": "production",
        "EXPO_PUBLIC_REVENUECAT_IOS_API_KEY": "appl_your_ios_production_public_sdk_key",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY": "goog_your_android_production_public_sdk_key",
        "EXPO_PUBLIC_REVENUECAT_OFFERING_ID": "default"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6791869174"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account-listingos.json",
        "track": "internal",
        "releaseStatus": "completed"
      }
    }
  }
}
